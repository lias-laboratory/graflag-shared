METHOD_NAME=gady
DESCRIPTION=Unsupervised Anomaly Detection on Dynamic Graphs (WSDM 2024)
SOURCE_CODE=https://github.com/mufeng-74/GADY

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=gady_*

COMMAND=python3 train_graflag.py

# Data Parameters
_ANOMALY_PER=0.1
_TRAIN_PER=0.7
_BS=200

# Model Architecture
_N_LAYER=2
_N_DEGREE=10
_MEMORY_DIM=172
_MESSAGE_DIM=100
_NODE_DIM=100
_TIME_DIM=1

# Memory Settings (boolean flags - empty = True, omit = False)
_USE_MEMORY=
_MESSAGE_FUNCTION=identity
_MEMORY_UPDATER=gru
_AGGREGATOR=last
# _MEMORY_UPDATE_AT_END=  # Uncomment to enable (default: False)

# Positional Features
_R_DIM=4
_BETA=0.00001

# Training Hyperparameters
_N_EPOCH=50
_N_RUNS=1
_LR=0.0001
_LR_G=0.000001
_LR_D=0.000001
_PATIENCE=5
_SEED=142
_GPU=0

# GAN Loss Parameters
_ALPHA=0.1
_BETAA=10
_GAMMA=0.1

# Mode
_MODE=0

# Other Settings
# _PREFIX=  # Uncomment and set value if needed
# Boolean flags (uncomment to enable, default: False)
# _UNIFORM=
# _RANDOMIZE_FEATURES=
# _USE_DESTINATION_EMBEDDING_IN_MESSAGE=
# _USE_SOURCE_EMBEDDING_IN_MESSAGE=
# _DIFFERENT_NEW_NODES=
