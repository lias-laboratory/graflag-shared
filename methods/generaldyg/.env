METHOD_NAME=generaldyg
DESCRIPTION=A Generalizable Anomaly Detection Method in Dynamic Graphs (AAAI 2025)
SOURCE_CODE=https://github.com/YXNTU/GeneralDyG

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=generaldyg_*

COMMAND=python3 train_graflag.py

# General Parameters
# Positive class name. Default: EU3
_NAME_POS=EU3
# Negative sample ratio. Default: 1
_RATIO_NEG=1
# Negative data ratio selection: 01, 05, 1. Default: 01
_NEG=01
# Maximum sequence length (e.g., 24 for wikipedia). Default: 24
_MAX_LEN=24

# Data Parameters
# Batch size. Default: 128
_BATCH_SIZE=128
# Number of epochs. Default: 200
_N_EPOCHS=200
# Number of data workers. Default: 0
_NUM_DATA_WORKERS=0
# Number of GPUs. Default: 1
_GPUS=1

# Model Parameters
# Path to the checkpoint file. Default: ./
_CKPT_FILE=./src/
# Input dimension. Default: 128
_INPUT_DIM=128
# Hidden layer dimension. Default: 258
_HIDDEN_DIM=258
# Number of attention heads. Default: 4
_N_HEADS=4
# Dropout rate. Default: 0.4
_DROP_OUT=0.4
# Number of network layers. Default: 6
_N_LAYER=6
# Learning rate. Default: 0.0001
_LEARNING_RATE=0.0001
# Random seed. Default: 95540
_SEED=95540
