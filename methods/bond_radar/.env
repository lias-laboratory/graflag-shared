METHOD_NAME=bond_radar
DESCRIPTION=Residual Analysis for Anomaly Detection in Attributed Networks
SOURCE_CODE=https://docs.pygod.org/en/latest/generated/pygod.detector.Radar.html#pygod.detector.Radar

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=bond_*

COMMAND=python3 -m graflag_bond.train

# Weight of node feature w.r.t. structure. Default:1.
_GAMMA=1
# Weight decay (L2 penalty). Default:0..
_WEIGHT_DECAY=0
# Learning rate. Default:0.004.
_LR=0.004
# Maximum number of training epoch. Default:100.
_EPOCH=100
# GPU Index, -1 for using CPU. Default:-1.
_GPU=0
# Valid in (0., 0.5). The proportion of outliers in the data set. Used when fitting to define the threshold on the decision function. Default:0.1.
_CONTAMINATION=0.1
# Verbosity mode. Range in [0, 3]. Larger value for printing out more log information. Default:0.
_VERBOSE=0