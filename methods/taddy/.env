METHOD_NAME=TADDY
DESCRIPTION=Temporal Anomaly Detection in Dynamic Networks via Transformer
SOURCE_CODE=https://github.com/yixingwang0517/Temporal-Anomaly-Detection-in-Dynamic-Graphs-via-Transformer

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=uci,btc_alpha,btc_otc,digg

COMMAND=python3 train_graflag.py

# Dataset parameters
_ANOMALY_PER=0.1
_TRAIN_PER=0.5

# Model architecture
_NEIGHBOR_NUM=5
_WINDOW_SIZE=2
_EMBEDDING_DIM=32
_NUM_HIDDEN_LAYERS=2
_NUM_ATTENTION_HEADS=2

# Training parameters
_MAX_EPOCH=200
_LEARNING_RATE=0.001
_WEIGHT_DECAY=0.0005
_SEED=1
_PRINT_FREQ=10

# GPU device index (-1 for CPU)
_GPU=0
