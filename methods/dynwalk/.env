METHOD_NAME=dynwalk
DESCRIPTION=NetWalk: A Flexible Deep Embedding Approach for Anomaly Detection in Dynamic Networks (KDD 2018)
SOURCE_CODE=https://github.com/chengw07/NetWalk

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=*_snapshot

COMMAND=python3 train_graflag.py

# Embedding dimension
_REPRESENTATION_SIZE=32

# Random walk parameters
_WALK_LENGTH=5
_NUMBER_WALKS=20


# Initial graph percentage for training embeddings
_INIT_PERCENT=0.5

# Autoencoder training
_LEARNING_RATE=0.001
_EPOCHS=50
_HIDDEN_SIZE=64

# K-means clusters for anomaly detection
_N_CLUSTERS=5

# Random seed
_SEED=42
