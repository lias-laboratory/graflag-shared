METHOD_NAME=bond_dmgd
DESCRIPTION=Deep Multiclass Graph Description
SOURCE_CODE=https://docs.pygod.org/en/latest/generated/pygod.detector.DMGD.html#pygod.detector.DMGD

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=bond_*

COMMAND=python3 -m graflag_bond.train

# Hidden dimension of model. Default:64.
_HID_DIM=64
# Total number of layers in model. Default:2.
_NUM_LAYERS=2
# Dropout rate. Default:0..
_DROPOUT=0
# Weight decay (L2 penalty). Default:0..
_WEIGHT_DECAY=0
# Activation function if not None. Default:torch.nn.functional.relu.
_ACT=torch.nn.functional.relu
# The backbone of the deep detector implemented in PyG. Default:torch_geometric.nn.GCN.
_BACKBONE=torch_geometric.nn.GCN
# The amount of contamination of the dataset in (0., 0.5], i.e., the proportion of outliers in the dataset. Used when fitting to define the threshold on the decision function. Default:0.1.
_CONTAMINATION=0.1
# Learning rate. Default:0.004.
_LR=0.004
# Maximum number of training epoch. Default:100.
_EPOCH=100
# GPU Index, -1 for using CPU. Default:-1.
_GPU=0
# Minibatch size, 0 for full batch training. Default:0.
_BATCH_SIZE=0
# Number of neighbors in sampling, -1 for all neighbors. Default:-1.
_NUM_NEIGH=-1
# Weight of the radius loss. Default:1.
_ALPHA=1
# Weight of the reconstruction loss. Default:1.
_BETA=1
# Weight of the homophily loss. Default:1.
_GAMMA=1
# The number of epochs for warm-up training. Default:2.
_WARMUP=2
# The number of clusters. Default:2.
_K=2
# Verbosity mode. Range in [0, 3]. Larger value for printing out more log information. Default:0.
_VERBOSE=0
# Whether to save the embedding. Default:False.
_SAVE_EMB=False
# Whether to compile the model withtorch_geometric.compile. Default:False.
_COMPILE_MODEL=False