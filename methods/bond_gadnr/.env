METHOD_NAME=bond_gadnr
DESCRIPTION=Graph Anomaly Detection via Neighborhood Reconstruction
SOURCE_CODE=https://docs.pygod.org/en/latest/generated/pygod.detector.GADNR.html#pygod.detector.GADNR

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=bond_*

COMMAND=python3 -m graflag_bond.train

# Hidden dimension of model. Default:64.
_HID_DIM=64
# Total number of layers in the backbone encoder model. Default:1.
_NUM_LAYERS=1
# The number of layers for the node degree decoder. Default:4.
_DEG_DEC_LAYERS=4
# The number of layers for the node feature decoder. Default:3.
_FEA_DEC_LAYERS=3
# The backbone of the deep detector implemented in PyG. Default:torch_geometric.nn.GCN.
_BACKBONE=torch_geometric.nn.GCN
# The number of samples for the neighborhood distribution. Default:2.
_SAMPLE_SIZE=2
# The number sample times to remove the noise during node feature and neighborhood distribution reconstruction. Default:3.
_SAMPLE_TIME=3
# The neighbor reconstruction loss.KLrepresents the KL divergence loss,W2represents the W2 loss. Default:KL.
_NEIGH_LOSS=KL
# The weight of the neighborhood reconstruction loss term. Default:1e-2.
_LAMBDA_LOSS1=1e-2
# The weight of the node feature reconstruction loss term. Default:1e-3.
_LAMBDA_LOSS2=1e-3
# The weight of the node degree reconstruction loss term. Default:1e-4.
_LAMBDA_LOSS3=1e-4
# Whether using the original loss proposed in the paper as the decision score, if not, using the proposed weighted decision score. Default:True.
_REAL_LOSS=True
# Learning rate. Default:0.01.
_LR=0.01
# Maximum number of training epoch. Default:100.
_EPOCH=100
# Dropout rate. Default:0..
_DROPOUT=0
# Weight decay (L2 penalty). Default:0.0003.
_WEIGHT_DECAY=0.0003
# Activation function if not None. Default:torch.nn.functional.relu.
_ACT=torch.nn.functional.relu
# GPU Index, -1 for using CPU. Default:-1.
_GPU=0
# Minibatch size, 0 for full batch training. Default:0.
_BATCH_SIZE=0
# Number of neighbors in sampling, -1 for all neighbors. Default:-1.
_NUM_NEIGH=-1
# The amount of contamination of the dataset in (0., 0.5], i.e., the proportion of outliers in the dataset. Used when fitting to define the threshold on the decision function. Default:0.1.
_CONTAMINATION=0.1
# Verbosity mode. Range in [0, 3]. Larger value for printing out more log information. Default:0.
_VERBOSE=0
# Whether to save the embedding. Default:False.
_SAVE_EMB=False
# Whether to compile the model withtorch_geometric.compile. Default:False.
_COMPILE_MODEL=False