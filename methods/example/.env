# ==============================================================================
# GraFlag Method Configuration Template
# ==============================================================================
# This file defines method metadata and default parameters.
# Copy this template to create a new method: cp -r example your_method_name
#
# IMPORTANT: Parameters starting with underscore (_) are passed to your script
# via --pass-env-args. For example, _LEARNING_RATE=0.001 becomes --learning_rate 0.001
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED: Method Metadata
# ------------------------------------------------------------------------------

# Unique method identifier (must match directory name)
METHOD_NAME=example

# Human-readable description (shown in method listings)
DESCRIPTION=Template method for GraFlag integration (copy this to create new methods)

# Link to original source code or paper
SOURCE_CODE=https://github.com/your-org/your-method

# ------------------------------------------------------------------------------
# OPTIONAL: Dataset Compatibility
# ------------------------------------------------------------------------------
# Comma-separated list of compatible datasets. Supports wildcards with *.
# Leave empty or omit to allow all datasets.
# Examples:
#   SUPPORTED_DATASETS=uci,btc_alpha,btc_otc    # Specific datasets
#   SUPPORTED_DATASETS=generaldyg_*              # Wildcard pattern
#   SUPPORTED_DATASETS=*_snapshot                # All snapshot datasets
SUPPORTED_DATASETS=

# ------------------------------------------------------------------------------
# REQUIRED: Execution Command
# ------------------------------------------------------------------------------

# Command to run your method (executed inside the Docker container)
# The graflag_runner will append --pass-env-args parameters to this command
COMMAND=python3 train_graflag.py

# ------------------------------------------------------------------------------
# OPTIONAL: Method Parameters (prefix with underscore)
# ------------------------------------------------------------------------------
# These become CLI arguments: _PARAM_NAME=value -> --param_name value
# Users can override via: ./graflag_cli.py benchmark -m method --params PARAM_NAME=new_value

# Learning rate for optimization
_LEARNING_RATE=0.001

# Number of training epochs
_EPOCHS=100

# Batch size for training
_BATCH_SIZE=32

# Hidden layer dimensions (can be any type, passed as string)
_HIDDEN_DIM=64

# Embedding dimension for node/edge representations
_EMBEDDING_DIM=32

# Random seed for reproducibility
_SEED=42

# ------------------------------------------------------------------------------
# NOTES:
# ------------------------------------------------------------------------------
# - Environment variables DATA and EXP are automatically set by GraFlag:
#   - DATA: Path to the dataset directory (e.g., /shared/datasets/your_dataset)
#   - EXP: Path to the experiment output directory
#
# - Your train_graflag.py must:
#   1. Parse arguments using argparse (to receive _PARAM values)
#   2. Load data from DATA path
#   3. Save results using ResultWriter to EXP path
#
# - Reserved environment variables (do not use):
#   - DATA, EXP, METHOD_NAME, COMMAND
# ==============================================================================
