METHOD_NAME=bond_one
DESCRIPTION=Outlier Aware Network Embedding for Attributed Networks
SOURCE_CODE=https://docs.pygod.org/en/latest/generated/pygod.detector.ONE.html#pygod.detector.ONE

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=bond_*

COMMAND=python3 -m graflag_bond.train

# Hidden dimension for the attribute. Default:36.
_HID_A=36
# Hidden dimension for the structure. Default:36.
_HID_S=36
# Weight for the attribute loss. Default:1..
_ALPHA=1
# Weight for the structural loss. Default:1..
_BETA=1
# Weight for the combined loss. Default:1..
_GAMMA=1
# Weight decay (L2 penalty). Default:0..
_WEIGHT_DECAY=0
# Valid in (0., 0.5). The proportion of outliers in the data set. Used when fitting to define the threshold on the decision function. Default:0.1.
_CONTAMINATION=0.1
# Learning rate. Default:0.004.
_LR=0.004
# Maximum number of training epoch. Default:5.
_EPOCH=5
# GPU Index, -1 for using CPU. Default:-1.
_GPU=0
# Verbosity mode. Range in [0, 3]. Larger value for printing out more log information. Default:0.
_VERBOSE=0