METHOD_NAME=anograph
DESCRIPTION=AnoGraph: Sketch-Based Anomaly Detection in Streaming Graphs (KDD 2023)
SOURCE_CODE=https://github.com/Stream-AD/AnoGraph

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=anograph_*

COMMAND=python3 train_graflag.py

# Algorithm selection: anograph, anographk, anoedgeg, anoedgel
_ALGORITHM=anograph

# Sketch parameters
# Number of rows in the sketch. Default: 2
_NUM_ROWS=2
# Number of columns (buckets) in the sketch. Default: 1024
_NUM_BUCKETS=1024

# Time window for aggregation. Default: 60
_TIME_WINDOW=60

# Edge threshold for anomaly labeling. Default: 100
_EDGE_THRESHOLD=100

# AnoGraph-K specific: number of elements for greedy search. Default: 5
_K=5

# AnoEdge threshold for anomaly score. Default: 0.9
_THRESHOLD=0.9

# Random seed. Default: 42
_SEED=42
