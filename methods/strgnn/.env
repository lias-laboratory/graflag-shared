METHOD_NAME=strgnn
DESCRIPTION=StrGNN: Structural Temporal Graph Neural Networks for Anomaly Detection in Dynamic Graphs (CIKM 2021)
SOURCE_CODE=https://github.com/KnowledgeDiscovery/StrGNN

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=*_snapshot

COMMAND=python3 train_graflag.py

# General settings
# Random seed. Default: 1
_SEED=1
# Test ratio (proportion of data for testing). Default: 0.2
_TEST_RATIO=0.2
# Window size (number of snapshots to consider). Default: 5
_WINDOW=5
# GPU device index. Default: 0
_GPU=0

# Model settings
# Enclosing subgraph hop number. Default: 1
_HOP=1
# Max nodes per hop (None for unlimited). Default: 100
_MAX_NODES_PER_HOP=100
# Whether to use node2vec embeddings. Default: 0 (False)
_USE_EMBEDDING=0

# DGCNN settings
# Sort pooling k (fraction if <= 1, absolute if > 1). Default: 0.6
_SORTPOOLING_K=0.6
# Hidden layer size. Default: 128
_HIDDEN=128
# Number of epochs. Default: 50
_NUM_EPOCHS=50
# Learning rate. Default: 0.0001
_LEARNING_RATE=0.0001
# Batch size. Default: 32
_BATCH_SIZE=32
# Dropout. Default: 1 (True)
_DROPOUT=1
