METHOD_NAME=addgraph
DESCRIPTION=AddGraph: Anomaly Detection in Dynamic Graph Using Attention-based Temporal GCN (IJCAI 2019)
SOURCE_CODE=https://github.com/Ljiajie/Addgraph

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=*_snapshot

COMMAND=python3 train_graflag.py

# Training settings
# Number of training epochs. Default: 100
_NUM_EPOCHS=100
# Learning rate for main optimizer. Default: 0.0008
_LEARNING_RATE=0.0008
# Learning rate for score network. Default: 0.0005
_LEARNING_RATE_SCORE=0.0005
# Hidden dimension size. Default: 100
_HIDDEN_DIM=100
# Number of attention heads for SpGAT. Default: 8
_NUM_HEADS=8
# Dropout rate. Default: 0.2
_DROPOUT=0.2
# Temporal window size. Default: 2
_WINDOW_SIZE=2
# Random seed. Default: 42
_SEED=42
# GPU device index. Default: 0
_GPU=0

# Loss function parameters
# Beta parameter for score function. Default: 1.0
_BETA=1.0
# Mui parameter (bias) for score function. Default: 0.3
_MUI=0.3
# Gamma parameter for margin loss. Default: 0.6
_GAMMA=0.6

# Data settings
# Training ratio (proportion of data for training). Default: 0.5
_TRAINING_RATIO=0.5
# Anomaly injection rate. Default: 0.1
_ANOMALY_RATE=0.1
