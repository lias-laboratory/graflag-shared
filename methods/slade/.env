METHOD_NAME=slade
DESCRIPTION=SLADE: Detecting Dynamic Anomalies in Edge Streams without Labels via Self-Supervised Learning
SOURCE_CODE=https://github.com/jhsk777/SLADE

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=slade_*

COMMAND=python3 train_graflag.py

# Training parameters
# Batch size. Default: 100
_BS=100
# Number of most recent neighbors to sample. Default: 20
_N_DEGREE=20
# Number of attention heads. Default: 2
_N_HEAD=2
# Number of epochs. Default: 10
_N_EPOCH=10
# Learning rate. Default: 3e-6
_LR=0.000003
# Number of runs. Default: 1
_N_RUNS=1
# Random seed. Default: 0
_SEED=0
# Dropout probability. Default: 0.1
_DROP_OUT=0.1

# Model parameters
# GPU index. Default: 0
_GPU=0
# Message dimension. Default: 128
_MESSAGE_DIM=128
# Memory dimension. Default: 256
_MEMORY_DIM=256
# Aggregation type (only TGAT). Default: TGAT
_AGG_TYPE=TGAT
# Negative memory type: train/random. Default: train
_NEGATIVE_MEMORY_TYPE=train
# Message updater type: mlp/identity. Default: mlp
_MESSAGE_UPDATER=mlp
# Memory updater type: gru/rnn. Default: gru
_MEMORY_UPDATER=gru

# Data parameters
# Training data ratio. Default: 0.85
_TRAINING_RATIO=0.85
# Learning rate decay ratio. Default: 0.8
_LR_DECAY=0.8
# Weight decay ratio. Default: 0.0001
_WEIGHT_DECAY=0.0001

# Loss weights
# Weight of source memory reconstruction contrastive loss. Default: 0.1
_SRF=0.1
# Weight of destination memory reconstruction contrastive loss. Default: 0.1
_DRF=0.1

# Ablation study flags (set to 1 to enable)
# Use only drift loss and score
_ONLY_DRIFT_LOSS_SCORE=0
# Use only recovery loss and score
_ONLY_RECOVERY_LOSS_SCORE=0
# Use both losses but only drift score
_ONLY_DRIFT_SCORE=0
# Use both losses but only recovery score
_ONLY_REC_SCORE=0
