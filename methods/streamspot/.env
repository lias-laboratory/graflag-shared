METHOD_NAME=streamspot
DESCRIPTION=StreamSpot: Graph-Based Anomaly Detection in System Provenance Data
SOURCE_CODE=https://github.com/sbustreamspot/sbustreamspot-core

# Supported datasets (comma-separated, wildcards allowed with *)
SUPPORTED_DATASETS=streamspot_*

COMMAND=python3 train_graflag.py

# StreamSpot Core Parameters
# Chunk length (shingle size). Default: 10
_CHUNK_LENGTH=10
# Number of parallel graphs to process. Default: 10
_NUM_PARALLEL_GRAPHS=10
# Maximum number of edges to process (-1 for all). Default: -1
_MAX_NUM_EDGES=-1
# Dataset subset: all, ydc (YouTube/Download/CNN), gfc (GMail/VGame/CNN). Default: all
_DATASET=all

# Training Parameters
# Training ratio for bootstrap cluster generation. Default: 0.5
_TRAINING_RATIO=0.5
# Random seed. Default: 42
_SEED=42

# Bootstrap Cluster Parameters (if not using pre-computed)
# Global similarity threshold. Default: 0.6
_GLOBAL_THRESHOLD=0.6
